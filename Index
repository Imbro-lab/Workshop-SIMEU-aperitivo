<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Iscrizione – Workshop SIMEU ER | 24 giugno 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: 'DM Sans', sans-serif;
  background: #0f172a;
  min-height: 100vh;
  display: flex;
  align-items: flex-start;
  justify-content: center;
  padding: 2rem 1rem 4rem;
}

.page {
  width: 100%;
  max-width: 680px;
  position: relative;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 24px 80px rgba(0,0,0,0.5);
}

.bg-scene {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(160deg,
    rgba(251,146,60,0.18) 0%,
    rgba(236,72,153,0.12) 50%,
    rgba(14,165,233,0.22) 100%);
}

.content {
  position: relative;
  z-index: 2;
  padding: 2.5rem 2rem 2.5rem;
}

/* ── HEADER ── */
.org-badge {
  display: inline-flex;
  align-items: center;
  gap: 7px;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #FEF3C7;
  background: rgba(249,115,22,0.55);
  border: 0.5px solid rgba(254,243,199,0.3);
  padding: 4px 14px;
  border-radius: 20px;
  margin-bottom: 14px;
}

.hero-title {
  font-family: 'Playfair Display', serif;
  font-size: 13px;
  font-weight: 400;
  color: rgba(254,243,199,0.75);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 6px;
}

.hero-main {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  font-weight: 600;
  color: #FEF9EE;
  line-height: 1.25;
  margin-bottom: 4px;
  text-shadow: 0 2px 20px rgba(0,0,0,0.3);
}

.hero-main em {
  font-style: italic;
  color: #FCD34D;
}

.hero-speakers {
  font-size: 13px;
  font-weight: 300;
  color: rgba(254,243,199,0.8);
  margin-bottom: 16px;
  line-height: 1.5;
}

.meta-row {
  display: flex;
  gap: 10px;
  flex-wrap: wrap;
  margin-bottom: 1.5rem;
}

.meta-pill {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: rgba(254,243,199,0.9);
  background: rgba(0,0,0,0.22);
  border: 0.5px solid rgba(254,243,199,0.2);
  padding: 5px 13px;
  border-radius: 20px;
  white-space: nowrap;
}
.meta-pill i { font-size: 13px; color: #FCD34D; }

/* ── DESCRIPTION CARD ── */
.desc-card {
  background: rgba(255,255,255,0.12);
  border: 0.5px solid rgba(255,255,255,0.22);
  border-radius: 12px;
  padding: 1.1rem 1.25rem;
  margin-bottom: 1.5rem;
}
.desc-card p {
  font-size: 13.5px;
  color: rgba(255,245,220,0.92);
  line-height: 1.65;
  font-weight: 300;
}
.desc-card p + p { margin-top: 10px; }
.desc-card strong {
  font-weight: 500;
  color: #FEF3C7;
}
.desc-highlight {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  margin-top: 12px;
  font-size: 13px;
  font-weight: 500;
  color: #FCD34D;
  background: rgba(249,115,22,0.18);
  border: 0.5px solid rgba(249,115,22,0.3);
  padding: 5px 12px;
  border-radius: 8px;
}

/* ── GLASS FORM CARD ── */
.glass-card {
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 0.5px solid rgba(255,255,255,0.65);
  border-radius: 16px;
  padding: 1.75rem;
  box-shadow: 0 8px 40px rgba(249,115,22,0.15);
}

.card-heading {
  font-family: 'Playfair Display', serif;
  font-size: 19px;
  font-weight: 600;
  color: #7C2D12;
  margin-bottom: 1.25rem;
  display: flex;
  align-items: center;
  gap: 10px;
}
.card-heading i { font-size: 18px; color: #F97316; }

.field { margin-bottom: 1.1rem; }
.field label {
  display: block;
  font-size: 11px;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: #92400E;
  margin-bottom: 5px;
}
.field input,
.field textarea {
  width: 100%;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  padding: 10px 13px;
  border: 1px solid rgba(249,115,22,0.28);
  border-radius: 10px;
  background: rgba(255,255,255,0.78);
  color: #1C0A00;
  outline: none;
  transition: border-color 0.15s, box-shadow 0.15s;
}
.field input:focus,
.field textarea:focus {
  border-color: #F97316;
  box-shadow: 0 0 0 3px rgba(249,115,22,0.14);
}
.field input::placeholder,
.field textarea::placeholder { color: #D1A06A; font-weight: 300; }
.field textarea { resize: vertical; }

.err {
  font-size: 11px;
  color: #DC2626;
  margin-top: 3px;
  display: none;
}

.field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

.privacy {
  display: flex;
  align-items: flex-start;
  gap: 9px;
  margin-bottom: 1.25rem;
}
.privacy input[type=checkbox] {
  width: 15px;
  height: 15px;
  margin-top: 2px;
  flex-shrink: 0;
  accent-color: #F97316;
  cursor: pointer;
}
.privacy label {
  font-size: 12px;
  color: #78350F;
  line-height: 1.55;
  cursor: pointer;
}

.btn-iscriviti {
  width: 100%;
  padding: 13px;
  font-family: 'DM Sans', sans-serif;
  font-size: 15px;
  font-weight: 500;
  letter-spacing: 0.02em;
  background: linear-gradient(135deg, #F97316 0%, #EC4899 100%);
  color: #fff;
  border: none;
  border-radius: 10px;
  cursor: pointer;
  transition: opacity 0.15s, transform 0.1s;
  box-shadow: 0 4px 18px rgba(249,115,22,0.35);
}
.btn-iscriviti:hover { opacity: 0.91; }
.btn-iscriviti:active { transform: scale(0.98); }

/* ── SUCCESS ── */
.success-box {
  display: none;
  text-align: center;
  padding: 1.5rem 0.5rem;
}
.success-icon { font-size: 46px; color: #F97316; margin-bottom: 12px; }
.success-box h2 {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  font-weight: 600;
  color: #7C2D12;
  margin-bottom: 8px;
}
.success-box p { font-size: 14px; color: #92400E; line-height: 1.6; }
.btn-altro {
  margin-top: 16px;
  padding: 9px 22px;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  background: transparent;
  border: 1px solid rgba(249,115,22,0.4);
  border-radius: 8px;
  cursor: pointer;
  color: #92400E;
}
.btn-altro:hover { background: rgba(249,115,22,0.08); }

/* ── ADMIN ── */
.admin-divider {
  display: flex;
  align-items: center;
  gap: 12px;
  margin: 1.75rem 0 1rem;
}
.admin-divider::before,
.admin-divider::after {
  content: '';
  flex: 1;
  height: 0.5px;
  background: rgba(254,243,199,0.28);
}
.admin-divider span {
  font-size: 11px;
  color: rgba(254,243,199,0.45);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  white-space: nowrap;
}

.admin-btn { display: flex; align-items: center; justify-content: center; }
.admin-btn button {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-family: 'DM Sans', sans-serif;
  font-size: 12px;
  color: rgba(254,243,199,0.55);
  background: rgba(0,0,0,0.2);
  border: 0.5px solid rgba(254,243,199,0.18);
  padding: 7px 18px;
  border-radius: 20px;
  cursor: pointer;
  letter-spacing: 0.04em;
  transition: all 0.15s;
}
.admin-btn button:hover { color: #FEF3C7; background: rgba(0,0,0,0.35); }

.admin-panel {
  display: none;
  background: rgba(255,255,255,0.9);
  backdrop-filter: blur(18px);
  border: 0.5px solid rgba(255,255,255,0.6);
  border-radius: 16px;
  padding: 1.5rem;
  margin-top: 1rem;
  box-shadow: 0 8px 40px rgba(249,115,22,0.12);
}
.admin-panel h3 {
  font-family: 'Playfair Display', serif;
  font-size: 16px;
  font-weight: 600;
  color: #7C2D12;
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: 8px;
}

.pwd-row { display: flex; gap: 8px; margin-bottom: 8px; }
.pwd-row input {
  flex: 1;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  padding: 9px 12px;
  border: 1px solid rgba(249,115,22,0.25);
  border-radius: 8px;
  background: rgba(255,255,255,0.85);
  color: #1C0A00;
  outline: none;
}
.pwd-row input:focus { border-color: #F97316; }
.pwd-row button {
  padding: 9px 16px;
  font-family: 'DM Sans', sans-serif;
  font-size: 13px;
  font-weight: 500;
  background: linear-gradient(135deg, #F97316, #EC4899);
  color: #fff;
  border: none;
  border-radius: 8px;
  cursor: pointer;
}
.pwd-hint { font-size: 11px; color: #A16207; margin-top: 4px; }
.pwd-err { font-size: 11px; color: #DC2626; display: none; margin-top: 4px; }

.admin-content { display: none; }

.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  margin-bottom: 14px;
}
.stat {
  background: rgba(254,243,199,0.5);
  border: 0.5px solid rgba(249,115,22,0.2);
  border-radius: 10px;
  padding: 12px;
  text-align: center;
}
.stat-n {
  font-family: 'Playfair Display', serif;
  font-size: 22px;
  color: #92400E;
  font-weight: 600;
}
.stat-l { font-size: 11px; color: #A16207; margin-top: 2px; }

.tbl-wrap {
  max-height: 240px;
  overflow-y: auto;
  border: 0.5px solid rgba(249,115,22,0.2);
  border-radius: 10px;
  background: rgba(255,255,255,0.75);
  margin-bottom: 12px;
}
table { width: 100%; border-collapse: collapse; font-size: 12px; table-layout: fixed; }
th {
  text-align: left;
  font-weight: 500;
  color: #92400E;
  padding: 8px 10px;
  border-bottom: 0.5px solid rgba(249,115,22,0.2);
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  position: sticky;
  top: 0;
  background: rgba(255,248,235,0.97);
}
td {
  padding: 8px 10px;
  border-bottom: 0.5px solid rgba(249,115,22,0.1);
  color: #1C0A00;
  word-break: break-word;
}
tr:last-child td { border-bottom: none; }
.no-data { text-align: center; color: #A16207; font-size: 12px; padding: 20px; }

.act-row { display: flex; gap: 8px; flex-wrap: wrap; }
.btn-csv, .btn-del {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 14px;
  font-family: 'DM Sans', sans-serif;
  font-size: 12px;
  border-radius: 8px;
  cursor: pointer;
  transition: background 0.15s;
}
.btn-csv {
  background: transparent;
  border: 1px solid rgba(249,115,22,0.35);
  color: #92400E;
}
.btn-csv:hover { background: rgba(249,115,22,0.08); }
.btn-del {
  background: transparent;
  border: 1px solid rgba(220,38,38,0.3);
  color: #DC2626;
}
.btn-del:hover { background: rgba(220,38,38,0.06); }

/* ── FOOTER ── */
.footer {
  text-align: center;
  margin-top: 1.75rem;
  font-size: 11px;
  color: rgba(254,243,199,0.38);
  letter-spacing: 0.04em;
}

@media (max-width: 480px) {
  .content { padding: 2rem 1.25rem 2rem; }
  .hero-main { font-size: 22px; }
  .field-row { grid-template-columns: 1fr; }
  .meta-row { gap: 8px; }
}
</style>
</head>
