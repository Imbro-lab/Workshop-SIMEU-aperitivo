<div class="overlay"></div>

<div class="content">

  <!-- HEADER -->
  <div class="org-badge">
    <i class="ti ti-building-hospital"></i> SIMEU Emilia-Romagna
  </div>

  <p class="hero-title">Workshop · In presenza</p>
  <h1 class="hero-main">Ricerca clinica:<br><em>come farla – come comunicarla</em></h1>
  <p class="hero-speakers">
    Dott. Michele Spampinato &amp; Dott. Lorenzo Demitry
  </p>

  <div class="meta-row">
    <div class="meta-pill"><i class="ti ti-calendar-event"></i> 24 giugno 2026</div>
    <div class="meta-pill"><i class="ti ti-clock"></i> Ore 16:15</div>
    <div class="meta-pill"><i class="ti ti-map-pin"></i> Bar Combo, Bologna</div>
    <div class="meta-pill"><i class="ti ti-map-2"></i> Via dei Carracci 69/14</div>
  </div>

  <!-- DESCRIPTION -->
  <div class="desc-card">
    <p>
      SIMEU Emilia-Romagna vi invita al prossimo workshop <strong>esclusivamente in presenza</strong>
      dedicato alla ricerca clinica in Medicina d'Urgenza: come progettarla, condurla e comunicarla
      in modo efficace. Un'occasione di formazione pratica con due relatori di riferimento del settore.
    </p>
    <p>
      A seguire, <strong>aperitivo sociale aperto a tutti</strong> — soci e non soci — al quale vi
      aspettiamo numerosi! Per consentirci di organizzare al meglio, vi chiediamo di iscrivervi
      tramite il form qui sotto: ci servirà un numero indicativo di partecipanti da comunicare al locale.
    </p>
    <div class="desc-highlight">
      <i class="ti ti-coin-euro"></i> Costo aperitivo: <strong>16 € a persona</strong>
    </div>
  </div>

  <!-- FORM -->
  <div class="glass-card">
    <div id="formWrap">
      <div class="card-heading">
        <i class="ti ti-edit"></i> Iscrizione all'aperitivo
      </div>

      <div class="field-row">
        <div class="field">
          <label for="fn">Nome <span style="color:#DC2626">*</span></label>
          <input type="text" id="fn" placeholder="Mario" autocomplete="given-name">
          <div class="err" id="e-fn">Campo obbligatorio</div>
        </div>
        <div class="field">
          <label for="fc">Cognome <span style="color:#DC2626">*</span></label>
          <input type="text" id="fc" placeholder="Rossi" autocomplete="family-name">
          <div class="err" id="e-fc">Campo obbligatorio</div>
        </div>
      </div>

      <div class="field">
        <label for="fe">Email <span style="color:#DC2626">*</span></label>
        <input type="email" id="fe" placeholder="mario.rossi@email.it" autocomplete="email">
        <div class="err" id="e-fe">Inserisci un'email valida</div>
      </div>

      <div class="privacy">
        <input type="checkbox" id="fp">
        <label for="fp">
          Acconsento al trattamento dei miei dati personali ai sensi del Regolamento UE 2016/679 (GDPR)
          per la gestione dell'iscrizione a questo evento.
        </label>
      </div>
      <div class="err" id="e-fp" style="margin-top:-8px;margin-bottom:14px">
        È necessario accettare per procedere
      </div>

      <button class="btn-iscriviti" onclick="doSubmit()">
        Iscriviti all'aperitivo ✦
      </button>
    </div>

    <div class="success-box" id="successBox">
      <div class="success-icon"><i class="ti ti-circle-check"></i></div>
      <h2>Ci vediamo il 24 giugno!</h2>
      <p>
        La tua iscrizione è stata registrata.<br>
        Ti aspettiamo al Bar Combo per il workshop e l'aperitivo.
      </p>
      <button class="btn-altro" onclick="doReset()">Iscrivine un altro</button>
    </div>
  </div>

  <!-- ADMIN -->
  <div class="admin-divider"><span>area organizzatore</span></div>

  <div class="admin-btn">
    <button id="aToggleBtn" onclick="toggleAdmin()">
      <i class="ti ti-lock"></i>&nbsp; Pannello partecipanti
    </button>
  </div>

  <div class="admin-panel" id="adminPanel">
    <h3><i class="ti ti-users"></i> Accesso organizzatore</h3>

    <div id="aLogin">
      <div class="pwd-row">
        <input type="password" id="aPwd" placeholder="Password" onkeydown="if(event.key==='Enter')checkPwd()">
        <button onclick="checkPwd()">Accedi</button>
      </div>
      <div class="pwd-err" id="aPwdErr">Password non corretta</div>
      <p class="pwd-hint">Modifica la password nella riga <code>const PWD</code> prima di pubblicare.</p>
    </div>

    <div class="admin-content" id="aContent">
      <div class="stats-grid">
        <div class="stat">
          <div class="stat-n" id="sTot">0</div>
          <div class="stat-l">Iscritti totali</div>
        </div>
        <div class="stat">
          <div class="stat-n" id="sOggi">0</div>
          <div class="stat-l">Oggi</div>
        </div>
        <div class="stat">
          <div class="stat-n" id="sUlt">—</div>
          <div class="stat-l">Ultimo iscritto</div>
        </div>
      </div>

      <div class="tbl-wrap">
        <table>
          <thead>
            <tr>
              <th style="width:28px">#</th>
              <th style="width:30%">Nome</th>
              <th style="width:38%">Email</th>
              <th style="width:25%">Data iscrizione</th>
            </tr>
          </thead>
          <tbody id="aTbody">
            <tr><td colspan="5" class="no-data">Nessun iscritto ancora.</td></tr>
          </tbody>
        </table>
      </div>

      <div class="act-row">
        <button class="btn-csv" onclick="doCSV()">
          <i class="ti ti-download"></i> Scarica CSV
        </button>
        <button class="btn-del" onclick="doClear()">
          <i class="ti ti-trash"></i> Cancella tutti
        </button>
      </div>
    </div>
  </div>

  <p class="footer">SIMEU Emilia-Romagna · Workshop 24 giugno 2026 · Bologna</p>

</div>
</div>

<script>
const KEY = 'simeu_workshop_240626';
const PWD = 'simeu2026';   // ← cambia questa password prima di pubblicare

function load() {
  try { return JSON.parse(localStorage.getItem(KEY) || '[]'); } catch { return []; }
}
function save(d) { localStorage.setItem(KEY, JSON.stringify(d)); }

function doSubmit() {
  let ok = true;
  const n  = document.getElementById('fn').value.trim();
  const c  = document.getElementById('fc').value.trim();
  const e  = document.getElementById('fe').value.trim();
  const p  = document.getElementById('fp').checked;

  document.querySelectorAll('.err').forEach(x => x.style.display = 'none');

  if (!n)  { document.getElementById('e-fn').style.display = 'block'; ok = false; }
  if (!c)  { document.getElementById('e-fc').style.display = 'block'; ok = false; }
  if (!e || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e)) {
    document.getElementById('e-fe').style.display = 'block'; ok = false;
  }
  if (!p)  { document.getElementById('e-fp').style.display = 'block'; ok = false; }
  if (!ok) return;

  const d   = load();
  const now = new Date();
  d.push({
    id:       d.length + 1,
    nome:     n,
    cognome:  c,
    email:    e,
    data_iso: now.toISOString(),
    data_fmt: now.toLocaleDateString('it-IT', { day: '2-digit', month: '2-digit', year: 'numeric' })
              + ' ' + now.toLocaleTimeString('it-IT', { hour: '2-digit', minute: '2-digit' })
  });
  save(d);

  document.getElementById('formWrap').style.display  = 'none';
  document.getElementById('successBox').style.display = 'block';
  if (document.getElementById('aContent').style.display === 'block') renderTable();
}

function doReset() {
  ['fn', 'fc', 'fe'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('fp').checked = false;
  document.querySelectorAll('.err').forEach(x => x.style.display = 'none');
  document.getElementById('successBox').style.display = 'none';
  document.getElementById('formWrap').style.display   = 'block';
}

function toggleAdmin() {
  const p = document.getElementById('adminPanel');
  const b = document.getElementById('aToggleBtn');
  if (p.style.display === 'block') {
    p.style.display = 'none';
    b.innerHTML = '<i class="ti ti-lock"></i>&nbsp; Pannello partecipanti';
  } else {
    p.style.display = 'block';
    b.innerHTML = '<i class="ti ti-lock-open"></i>&nbsp; Chiudi pannello';
  }
}

function checkPwd() {
  if (document.getElementById('aPwd').value === PWD) {
    document.getElementById('aLogin').style.display   = 'none';
    document.getElementById('aContent').style.display = 'block';
    renderTable();
  } else {
    document.getElementById('aPwdErr').style.display = 'block';
    document.getElementById('aPwd').value = '';
  }
}

function renderTable() {
  const d = load();
  document.getElementById('sTot').textContent  = d.length;
  const oggi = new Date().toLocaleDateString('it-IT');
  document.getElementById('sOggi').textContent =
    d.filter(r => new Date(r.data_iso).toLocaleDateString('it-IT') === oggi).length;
  document.getElementById('sUlt').textContent  = d.length ? d[d.length - 1].cognome : '—';

  const tb = document.getElementById('aTbody');
  if (!d.length) {
    tb.innerHTML = '<tr><td colspan="5" class="no-data">Nessun iscritto ancora.</td></tr>';
    return;
  }
  tb.innerHTML = [...d].reverse().map(r => `
    <tr>
      <td style="color:#A16207">${r.id}</td>
      <td><strong>${r.nome} ${r.cognome}</strong></td>
      <td style="color:#78350F">${r.email}</td>
      <td style="color:#A16207;white-space:nowrap;font-size:11px">${r.data_fmt}</td>
    </tr>`).join('');
}

function doCSV() {
  const d = load();
  if (!d.length) { alert('Nessun iscritto da scaricare.'); return; }
  const header = ['#', 'Nome', 'Cognome', 'Email', 'Data iscrizione'];
  const rows   = d.map(r => [r.id, r.nome, r.cognome, r.email, r.data_fmt]);
  const csv    = [header, ...rows]
    .map(r => r.map(c => '"' + String(c).replace(/"/g, '""') + '"').join(','))
    .join('\n');
  const a = document.createElement('a');
  a.href     = URL.createObjectURL(new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' }));
  a.download = 'iscritti_workshop_SIMEU_240626.csv';
  a.click();
  URL.revokeObjectURL(a.href);
}

function doClear() {
  if (!confirm('Cancellare tutti gli iscritti? Questa azione è irreversibile.')) return;
  localStorage.removeItem(KEY);
  renderTable();
}
</script>

</body>
</html>
